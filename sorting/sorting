#include<bits/stdc++.h>
using namespace std;

class Solution {
    public:
        void swap(vector <int> &nums, int i, int j){

        int temp= nums[i];
        nums[i]=nums[j];
        nums[j]=temp;

        return;
    }

        vector<int> selectionSort(vector<int>& nums) {

            int i=0, n=nums.size();
            while(i<n-1){
                int j=i;
                int minNum=nums[i], idx=i;
                while(j<n){
                    if(minNum>nums[j]){
                        idx=j;
                        minNum=nums[j];
                    }
                    j++;
                }
                swap(nums, i,idx);
                i++;
            }
            return nums;
    }

        vector<int> bubbleSort(vector<int> & nums){
        int n=nums.size();
        int i=n-1;
        while(i>0){
            int j=0, k=1;
            while(k<=i){
                if(nums[j]>nums[k]) swap(nums, j,k);
                j++;
                k++;
            }
            i--;
        }

        return nums;
    }

        vector<int> insertionSort(vector<int> &nums){
        int n=nums.size();
        int p1=1;
        while(p1<n){
            int p2=p1+1;
            while(p2>0 && nums[p2]<nums[p2-1]){
                swap(nums, p2, p2-1);
                p2--;
            }
            p1++;
        }

        return nums;
    }

        int partition(vector<int> &nums, int begin, int end){

    int pivot = nums[begin];
    int i = begin + 1;
    int j = end;

    while(true){

            while(i <= end && nums[i] <= pivot)
                i++;

            while(nums[j] > pivot)
               j--;

            if(i >= j)
                break;

            swap(nums[i], nums[j]);
        }

        swap(nums[begin], nums[j]);

        return j;
    }   
    
        void quickSort(vector<int> &nums, int begin, int end){

        if(begin >= end)
            return;

        int p = partition(nums, begin, end);

        quickSort(nums, begin, p - 1);
        quickSort(nums, p + 1, end);
    }


};

