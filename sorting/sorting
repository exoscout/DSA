#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
        void swap(vector <int> &nums, int i, int j){

        int temp= nums[i];
        nums[i]=nums[j];
        nums[j]=temp;

        return;
    }

    vector<int> selectionSort(vector<int>& nums) {

        int i=0, n=nums.size();
        while(i<n-1){
            int j=i;
            int minNum=nums[i], idx=i;
            while(j<n){
                if(minNum>nums[j]){
                    idx=j;
                    minNum=nums[j];
                }
                j++;
            }
            swap(nums, i,idx);
            i++;
        }
        return nums;
    }


};

